# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/actipass

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ─── Application ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Rate limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=gmail
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM=noreply@actipass.fr

# ─── OVH Object Storage (S3-compatible) ───────────────────────────────────────
# Région : gra (Gravelines) ou sbg (Strasbourg)
OVH_S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net
OVH_S3_REGION=gra
OVH_S3_ACCESS_KEY=
OVH_S3_SECRET_KEY=
OVH_S3_BUCKET=actipass-documents
