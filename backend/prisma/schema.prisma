generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String             @id @default(uuid())
  email                      String             @unique
  password                   String?
  is_minor                   Boolean            @default(false)
  firstname                  String
  lastname                   String
  phone                      String?
  birthdate                  DateTime?
  gender                     Gender
  avatar_url                 String?
  username                   String             @unique
  is_email_verified          Boolean            @default(false)
  last_login_at              DateTime?
  status                     UserStatus         @default(pending)
  created_at                 DateTime           @default(now())
  updated_at                 DateTime           @updatedAt
  deleted_at                 DateTime?
  email_verification_expires DateTime?
  email_verification_token   String?            @unique
  failed_login_attempts      Int                @default(0)
  locked_until               DateTime?
  is_super_admin             Boolean            @default(false)
  password_reset_expires     DateTime?
  password_reset_token       String?            @unique
  refresh_token_hash         String?
  two_factor_enabled         Boolean            @default(false)
  two_factor_secret          String?
  profile_mode               ProfileMode        @default(solo)
  attendancesChecked         Attendance[]       @relation("AttendanceCheckedBy")
  attendancesCorrected       Attendance[]       @relation("AttendanceCorrectedBy")
  attendances                Attendance[]       @relation("UserAttendances")
  parentLinks                FamilyLink[]       @relation("ParentLinks")
  childLinks                 FamilyLink[]       @relation("ChildLinks")
  availabilityCreated        AvailabilitySlot[] @relation("AvailabilityCreatedBy")
  availabilitySlots          AvailabilitySlot[] @relation("UserAvailabilitySlots")
  ConflictCheck              ConflictCheck[]
  documents_uploaded         Document[]
  documents_validated        Document[]         @relation("DocumentValidatedBy")
  events_created             Event[]            @relation("EventCreatedBy")
  Invoice                    Invoice[]
  listings_created           Listing[]
  memberships                Membership[]
  organisations_created      Organisation[]
  payments_created_manual    Payment[]          @relation("PaymentsCreated")
  payments_made              Payment[]          @relation("PaymentsMade")
  Penalty                    Penalty[]
  privateCoursesAsStudent    PrivateCourse[]    @relation("StudentCourses")
  privateCoursesAsTutor      PrivateCourse[]    @relation("TutorCourses")
  subscriptions              Subscription[]
  auditLogs                  AuditLog[]
  healthInfo                 ChildHealthInfo?
  childAuthorizations        ChildAuthorization[] @relation("ChildAuthorizations")
  parentAuthorizations       ChildAuthorization[] @relation("ParentAuthorizations")

  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  name        String
  slug        String           @unique
  description String?
  is_default  Boolean          @default(false)
  level       Int
  space       UserSpace
  type        RoleType
  created_at  DateTime         @default(now())
  deleted_at  DateTime?
  updated_at  DateTime         @updatedAt
  memberships Membership[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  resource    String // 'events', 'members', 'payments', etc.
  action      String // 'create', 'read', 'update', 'delete', 'manage'
  scope       String // 'own', 'organisation', 'global'
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id            String   @id @default(uuid())
  role_id       String
  permission_id String
  created_at    DateTime @default(now())

  role       Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@unique([role_id, permission_id])
  @@map("role_permissions")
}

model Membership {
  id                 String                  @id @default(uuid())
  user_id            String
  organisation_id    String
  role_id            String
  license_number     String?
  joined_at          DateTime                @default(now())
  left_at            DateTime?
  adhesion_year      Int?
  is_paid            Boolean                 @default(false)
  validated          Boolean                 @default(false)
  is_main_membership Boolean                 @default(false)
  comment            String?
  status             MembershipStatus        @default(pending)
  docs_status        MembershipDocsStatus    @default(missing)
  payment_status     MembershipPaymentStatus @default(not_paid)
  created_at         DateTime                @default(now())
  deleted_at         DateTime?
  updated_at         DateTime                @updatedAt
  Invoice            Invoice[]
  organisation       Organisation            @relation(fields: [organisation_id], references: [id])
  role               Role                    @relation(fields: [role_id], references: [id])
  user               User                    @relation(fields: [user_id], references: [id])
  Reservation        Reservation[]

  @@index([user_id, organisation_id])
  @@index([user_id, status])
  @@map("memberships")
}

model Organisation {
  id            String                 @id @default(uuid())
  name          String
  slug          String                 @unique
  description   String?
  logo_url      String?
  type          OrganisationType
  address       String?
  city          String?
  zip_code      String?
  country       String?
  latitude      Float?
  longitude     Float?
  email         String?
  phone         String?
  website_url   String?
  member_limit  Int?
  is_public     Boolean                @default(true)
  status        OrganisationStatus     @default(active)
  created_by_id String
  created_at    DateTime               @default(now())
  updated_at    DateTime               @updatedAt
  deleted_at    DateTime?
  document      Document[]
  events        Event[]
  Invoice       Invoice[]
  listings      Listing[]
  memberships   Membership[]
  categories    OrganisationCategory[]
  created_by    User                   @relation(fields: [created_by_id], references: [id])
  Payment       Payment[]
  plans         Plan[]
  subscriptions Subscription[]

  @@map("organisations")
}

model Category {
  id                 String                 @id @default(uuid())
  name               String
  type               CategoryType
  description        String?
  icon               String?
  color              String?
  parent_category_id String?
  is_active          Boolean                @default(true)
  sort_order         Int                    @default(0)
  created_at         DateTime               @default(now())
  updated_at         DateTime               @updatedAt
  deleted_at         DateTime?
  parent_category    Category?              @relation("CategoryToParent", fields: [parent_category_id], references: [id])
  subcategories      Category[]             @relation("CategoryToParent")
  events             EventCategory[]
  listings           ListingCategory[]
  organisationLinks  OrganisationCategory[]

  @@index([type, is_active])
  @@map("categories")
}

model EventCategory {
  event_id    String
  category_id String
  category    Category @relation(fields: [category_id], references: [id], onDelete: Cascade)
  event       Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@id([event_id, category_id])
  @@map("event_categories")
}

model ListingCategory {
  listing_id  String
  category_id String
  category    Category @relation(fields: [category_id], references: [id], onDelete: Cascade)
  listing     Listing  @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  @@id([listing_id, category_id])
  @@map("listing_categories")
}

model OrganisationCategory {
  organisation_id String
  category_id     String
  category        Category     @relation(fields: [category_id], references: [id])
  organisation    Organisation @relation(fields: [organisation_id], references: [id])

  @@id([organisation_id, category_id])
  @@map("organisation_categories")
}

model Event {
  id                    String             @id @default(uuid())
  organisation_id       String
  linked_listing_id     String?
  parent_event_id       String? // Pour les séries récurrentes : référence l'événement parent
  title                 String
  description           String?
  event_type            EventType
  start_time            DateTime
  end_time              DateTime
  location              String?
  created_by_id         String
  visibility            EventVisibility
  capacity              Int?
  registration_required Boolean            @default(false)
  price                 Float              @default(0)
  is_recurring          Boolean            @default(false)
  recurrence_pattern    String? // JSON string pour la récurrence
  status                EventStatus        @default(draft)
  cover_url             String?
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt
  deleted_at            DateTime?
  Attendance            Attendance[]
  AvailabilitySlot      AvailabilitySlot[]
  EventCategory         EventCategory[]
  created_by            User               @relation("EventCreatedBy", fields: [created_by_id], references: [id])
  linked_listing        Listing?           @relation(fields: [linked_listing_id], references: [id])
  organisation          Organisation       @relation(fields: [organisation_id], references: [id])
  parent_event          Event?             @relation("EventRecurrence", fields: [parent_event_id], references: [id])
  recurring_occurrences Event[]            @relation("EventRecurrence")
  Invoice               Invoice[]
  Reservation           Reservation[]

  @@index([organisation_id, start_time])
  @@index([start_time, end_time, status])
  @@index([parent_event_id])
  @@map("events")
}

model Listing {
  id               String            @id @default(uuid())
  user_id          String
  organisation_id  String?
  title            String
  description      String?
  price_per_hour   Float
  session_duration Int
  is_online        Boolean           @default(false)
  visibility       ListingVisibility @default(public)
  available_from   DateTime?
  available_to     DateTime?
  languages        String[]
  specialities     String[]
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  deleted_at       DateTime?
  events           Event[]
  ListingCategory  ListingCategory[]
  organisation     Organisation?     @relation(fields: [organisation_id], references: [id])
  user             User              @relation(fields: [user_id], references: [id])
  privateCourses   PrivateCourse[]

  @@index([user_id, visibility])
  @@map("listings")
}

model PrivateCourse {
  id         String              @id @default(uuid())
  tutor_id   String
  student_id String
  listing_id String
  start_time DateTime
  end_time   DateTime
  location   String
  status     PrivateCourseStatus @default(pending)
  notes      String?
  rating     Float?
  created_at DateTime            @default(now())
  updated_at DateTime            @updatedAt
  deleted_at DateTime?
  paymentId  String?
  Invoice    Invoice[]
  Penalty    Penalty[]
  listing    Listing             @relation(fields: [listing_id], references: [id])
  payment    Payment?            @relation(fields: [paymentId], references: [id])
  student    User                @relation("StudentCourses", fields: [student_id], references: [id])
  tutor      User                @relation("TutorCourses", fields: [tutor_id], references: [id])

  @@index([tutor_id, status])
  @@index([student_id, status])
  @@map("private_courses")
}

model Document {
  id               String         @id @default(uuid())
  user_id          String
  organisation_id  String?
  type             DocumentType
  url              String
  doc_key          String
  file_name        String
  file_type        String
  status           DocumentStatus @default(pending)
  comment          String?
  expiration_date  DateTime?
  uploaded_at      DateTime       @default(now())
  validated_by_id  String?
  last_reviewed_at DateTime?
  deleted_at       DateTime?
  organisation     Organisation?  @relation(fields: [organisation_id], references: [id])
  user             User           @relation(fields: [user_id], references: [id])
  validated_by     User?          @relation("DocumentValidatedBy", fields: [validated_by_id], references: [id])

  @@index([user_id, type, status])
  @@map("documents")
}

model Reservation {
  id            String            @id @default(uuid())
  membership_id String
  event_id      String
  status        ReservationStatus @default(pending)
  payment_id    String?
  note          String?
  rating        Float?
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt
  deleted_at    DateTime?
  event         Event             @relation(fields: [event_id], references: [id])
  membership    Membership        @relation(fields: [membership_id], references: [id])

  @@unique([membership_id, event_id])
  @@index([event_id, status])
  @@map("reservations")
}

model Payment {
  id              String            @id @default(uuid())
  user_id         String
  organisation_id String?
  amount          Decimal
  currency        String            @default("EUR")
  payment_type    PaymentType
  status          PaymentStatus
  transaction_id  String?
  method_details  Json?
  created_by_id   String?
  notes           String?
  payment_date    DateTime?
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  target_id       String
  target_type     PaymentTargetType
  purpose         PaymentPurpose
  created_by      User?             @relation("PaymentsCreated", fields: [created_by_id], references: [id])
  organisation    Organisation?     @relation(fields: [organisation_id], references: [id])
  user            User              @relation("PaymentsMade", fields: [user_id], references: [id])
  PrivateCourse   PrivateCourse[]

  @@index([target_type, target_id])
  @@index([user_id, target_type])
  @@index([organisation_id, target_type])
  @@index([status, target_type])
  @@index([created_at])
  @@map("payments")
}

model Plan {
  id                String         @id @default(uuid())
  organisation_id   String
  name              String
  slug              String         @unique
  description       String?
  price             Decimal
  duration_days     Int
  max_sessions      Int?
  recurrence        Recurrence     @default(none)
  is_visible        Boolean        @default(true)
  stripe_product_id String?
  target_audience   TargetAudience
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  deleted_at        DateTime?
  organisation      Organisation   @relation(fields: [organisation_id], references: [id])
  subscriptions     Subscription[]

  @@index([organisation_id, is_visible])
  @@map("plans")
}

model Subscription {
  id                     String             @id @default(uuid())
  user_id                String
  plan_id                String
  organisation_id        String
  status                 SubscriptionStatus @default(active)
  start_date             DateTime
  end_date               DateTime
  remaining_sessions     Int?
  stripe_subscription_id String?
  is_recurring           Boolean            @default(true)
  cancelled_at           DateTime?
  created_at             DateTime           @default(now())
  updated_at             DateTime           @updatedAt
  deleted_at             DateTime?
  Invoice                Invoice[]
  organisation           Organisation       @relation(fields: [organisation_id], references: [id])
  plan                   Plan               @relation(fields: [plan_id], references: [id])
  user                   User               @relation(fields: [user_id], references: [id])

  @@index([user_id, status])
  @@index([organisation_id, status])
  @@map("subscriptions")
}

model Invoice {
  id                String         @id @default(uuid())
  invoice_number    String         @unique
  user_id           String
  organisation_id   String?
  membership_id     String?
  subscription_id   String?
  event_id          String?
  private_course_id String?
  total_amount      Decimal
  currency          String         @default("EUR")
  issued_at         DateTime       @default(now())
  due_date          DateTime?
  status            InvoiceStatus  @default(pending)
  notes             String?
  created_at        DateTime       @default(now())
  deleted_at        DateTime?
  updated_at        DateTime       @updatedAt
  event             Event?         @relation(fields: [event_id], references: [id])
  membership        Membership?    @relation(fields: [membership_id], references: [id])
  organisation      Organisation?  @relation(fields: [organisation_id], references: [id])
  private_course    PrivateCourse? @relation(fields: [private_course_id], references: [id])
  subscription      Subscription?  @relation(fields: [subscription_id], references: [id])
  user              User           @relation(fields: [user_id], references: [id])

  @@index([user_id, status])
  @@index([organisation_id, status])
  @@map("invoices")
}

model Attendance {
  id                String           @id @default(uuid())
  user_id           String
  event_id          String
  status            AttendanceStatus @default(present)
  checked_in_by     String?
  performance_notes String?
  score             Decimal?         @db.Decimal(5, 2)
  type              AttendanceType   @default(manual)
  comment           String?
  correction_by     String?
  correction_date   DateTime?
  correction_note   String?
  validated_at      DateTime?
  updated_at        DateTime         @updatedAt
  qr_code           String?          @unique
  created_at        DateTime         @default(now())
  checker           User?            @relation("AttendanceCheckedBy", fields: [checked_in_by], references: [id])
  corrector         User?            @relation("AttendanceCorrectedBy", fields: [correction_by], references: [id])
  event             Event            @relation(fields: [event_id], references: [id])
  user              User             @relation("UserAttendances", fields: [user_id], references: [id])

  @@unique([user_id, event_id])
  @@index([event_id, status])
  @@map("attendances")
}

model AvailabilitySlot {
  id           String           @id @default(uuid())
  user_id      String
  visibility   Visibility       @default(private)
  comment      String?
  created_by   String
  created_at   DateTime         @default(now())
  day_of_week  Int
  deleted_at   DateTime?
  end_time     String
  eventId      String?
  is_recurring Boolean          @default(true)
  slot_type    AvailabilityType
  start_time   String
  updated_at   DateTime         @updatedAt
  valid_from   DateTime         @default(now())
  valid_until  DateTime?
  creator      User             @relation("AvailabilityCreatedBy", fields: [created_by], references: [id])
  Event        Event?           @relation(fields: [eventId], references: [id])
  user         User             @relation("UserAvailabilitySlots", fields: [user_id], references: [id])

  @@index([user_id, day_of_week, slot_type])
  @@map("availability_slots")
}

model ConflictCheck {
  id         String   @id @default(uuid())
  user_id    String
  start_time DateTime
  end_time   DateTime
  event_type String
  event_id   String?
  priority   Int      @default(1)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])

  @@index([user_id, start_time, end_time])
  @@map("conflict_checks")
}

model Penalty {
  id                String         @id @default(uuid())
  user_id           String
  type              PenaltyType
  related_course_id String?
  description       String
  points            Int
  issued_at         DateTime       @default(now())
  resolved          Boolean        @default(false)
  amount            Decimal?
  related_course    PrivateCourse? @relation(fields: [related_course_id], references: [id])
  user              User           @relation(fields: [user_id], references: [id])

  @@index([user_id, resolved])
  @@map("penalties")
}

model AuditLog {
  id              String   @id @default(uuid())
  user_id         String
  action          String // create, update, delete, export, approve, login, etc.
  resource_type   String // events, members, payments, etc.
  resource_id     String?
  organisation_id String?
  details         Json?
  ip_address      String?
  user_agent      String?
  timestamp       DateTime @default(now())
  user            User     @relation(fields: [user_id], references: [id])

  @@index([user_id, timestamp])
  @@index([organisation_id, timestamp])
  @@index([resource_type, resource_id])
  @@index([action, timestamp])
  @@map("audit_logs")
}

enum Gender {
  male
  female
  prefer_not_to_say
}

enum UserStatus {
  active
  suspended
  pending
  locked
}

enum MembershipStatus {
  pending
  active
  banned
}

enum MembershipDocsStatus {
  missing
  in_review
  validated
}

enum MembershipPaymentStatus {
  not_paid
  pending
  paid
  overdue
}

enum OrganisationType {
  sport
  culture
  loisir
  social
  other
}

enum OrganisationStatus {
  active
  suspended
  pending_validation
}

enum CategoryType {
  sport
  wellbeing
  hobby
  academic
  music
  languages
  career
  other
}

enum EventType {
  training
  match
  meeting
  workshop
  other
}

enum EventVisibility {
  public
  members_only
  private
}

enum EventStatus {
  draft
  published
  cancelled
}

enum ListingVisibility {
  public
  hidden
}

enum PrivateCourseStatus {
  pending
  confirmed
  cancelled
  completed
}

enum DocumentType {
  id_card
  b3
  medical_certificate
  other
}

enum DocumentStatus {
  pending
  validated
  rejected
}

enum ReservationStatus {
  pending
  confirmed
  cancelled
  attended
  missed
}

enum PaymentTargetType {
  membership
  event
  private_course
  subscription
  penalty
  invoice
  plan
  manual
}

enum PaymentPurpose {
  membership_fee
  event_participation
  private_lesson
  subscription_fee
  penalty_fee
  equipment_rental
  registration_fee
  late_fee
  cancellation_fee
  refund
  discount
  deposit
  other
}

enum PaymentType {
  stripe
  cash
  transfer
  cheque
  other
  paypal
}

enum PaymentStatus {
  paid
  pending
  failed
  refunded
  cancelled
}

enum Recurrence {
  none
  weekly
  monthly
  annually
}

enum TargetAudience {
  member
  non_member
  tutor
}

enum SubscriptionStatus {
  active
  paused
  cancelled
  expired
}

enum InvoiceStatus {
  pending
  paid
  overdue
  cancelled
}

enum AttendanceStatus {
  present
  late
  absent
  excused
}

enum AttendanceType {
  manual
  self
  auto
}

enum AvailabilityType {
  available
  busy
  preferred
  blackout
}

enum Visibility {
  private
  user_only
  public
}

enum PenaltyType {
  no_show
  late_cancellation
  admin
}

enum UserSpace {
  club_360 // Espace 360° (associatif/privé)
  municipality // Portail Propriétaire (Mairie)
}

enum RoleType {
  // Espace 360° - Rôles optimisés
  club_owner // Propriétaire (tous droits)
  club_manager // Gestionnaire (gestion opérationnelle)
  treasurer // Trésorier (finances uniquement)
  coach // Coach (ses cours + présences)
  member // Membre (lecture + réservations)

  // Portail Propriétaire - Rôles municipaux
  municipal_admin // Admin municipal (tous droits)
  municipal_manager // Gestionnaire (équipements + subventions)
  municipal_viewer // Lecteur (données agrégées)
}

model FamilyLink {
  id                 String             @id @default(uuid())
  parent_id          String
  child_id           String
  relationship       FamilyRelationship @default(parent)
  is_primary_contact Boolean            @default(true)
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  parent             User               @relation("ParentLinks", fields: [parent_id], references: [id], onDelete: Cascade)
  child              User               @relation("ChildLinks", fields: [child_id], references: [id], onDelete: Cascade)

  @@unique([parent_id, child_id])
  @@index([parent_id])
  @@index([child_id])
  @@map("family_links")
}

enum FamilyRelationship {
  parent
  tuteur
  autre
}

enum ProfileMode {
  solo
  duo
  famille
}

enum AuthorizationType {
  photo_rights
  excursion
  medical_waiver
}

model ChildHealthInfo {
  id                         String   @id @default(uuid())
  child_id                   String   @unique
  blood_type                 String?
  allergies                  String[]
  no_known_allergies         Boolean  @default(false)
  treatments                 String[]
  no_known_treatments        Boolean  @default(false)
  medical_notes              String?
  emergency_contact_name     String?
  emergency_contact_phone    String?
  emergency_contact_relation String?
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt
  child                      User     @relation(fields: [child_id], references: [id], onDelete: Cascade)

  @@map("child_health_info")
}

model ChildAuthorization {
  id          String            @id @default(uuid())
  child_id    String
  parent_id   String
  type        AuthorizationType
  title       String
  description String?
  is_signed   Boolean           @default(false)
  signed_at   DateTime?
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  child       User              @relation("ChildAuthorizations", fields: [child_id], references: [id], onDelete: Cascade)
  parent      User              @relation("ParentAuthorizations", fields: [parent_id], references: [id])

  @@unique([child_id, type])
  @@index([parent_id])
  @@map("child_authorizations")
}
